# Production URLs
NEXT_PUBLIC_API_URL=""
NEXT_PUBLIC_GRPC_URL="http://localhost:8081"

# Foursquare Places import
FOURSQUARE_API_KEY=""
FOURSQUARE_NEAR="Serbia"
FOURSQUARE_API_VERSION="2025-06-17"
# Leave blank for complete vendor-name coverage across pharmacies and relevant
# supplement/health shops. Setting category IDs can reduce API calls, but may
# miss shops that Foursquare classifies outside Pharmacy/Drugstore.
FOURSQUARE_CATEGORY_IDS=""
# Serbia bounds as south,west,north,east. Use "near" to fall back to one broad
# Foursquare near search per vendor, which is faster but capped at 50 results.
FOURSQUARE_COVERAGE_BOUNDS="42.2322,18.8170,46.1900,23.0063"
FOURSQUARE_MAX_SPLIT_DEPTH="8"
# Leave blank to use the app's photo-capable default field list. It requests
# photos plus rich place details such as tel, website, hours, rating, and email,
# which may require Foursquare API credits.
FOURSQUARE_FIELDS=""
FOURSQUARE_SEARCH_LIMIT="50"
FOURSQUARE_REQUEST_SLEEP="250ms"
FOURSQUARE_PRUNE_DISALLOWED="true"
FOURSQUARE_PRUNE_STALE="true"
FOURSQUARE_CONTINUE_ON_ERROR="false"
