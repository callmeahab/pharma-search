# Database Configuration
DATABASE_URL="postgresql://postgres:docker@localhost:5432/pharma_search?sslmode=disable"

# Production Database (for server)
# DATABASE_URL="postgresql://root:pharma_secure_password_2025@localhost:5432/pharma_search"

# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="apostekafm@gmail.com"
SMTP_PASS="your-app-password-here"
CONTACT_EMAIL="apostekafm@gmail.com"

# Server Configuration (for deployment scripts)
SERVER_HOST="138.197.180.107"
SERVER_USER="root"
SERVER_PORT="22"

# Local Database (for upload scripts)
LOCAL_DB_NAME="pharma_search"
LOCAL_DB_USER="postgres"
LOCAL_DB_PASSWORD="docker"

# Production URLs
NEXT_PUBLIC_API_URL=""
NEXT_PUBLIC_GRPC_URL="http://localhost:8081"

# Local places import
# Sources are local-only and run from the dev machine with `make fetch-places`.
# OSM does not need an API key. TomTom/Foursquare are skipped if selected with no
# key unless PLACE_REQUIRE_ALL_SOURCES=true.
PLACE_SOURCES="osm,tomtom,foursquare"
PLACE_REQUIRE_ALL_SOURCES="false"

# TomTom Search import
TOMTOM_API_KEY=""
TOMTOM_BASE_URL="https://api.tomtom.com"
TOMTOM_COUNTRY_SET="RS"
TOMTOM_SEARCH_LIMIT="100"
TOMTOM_MAX_PAGES="20"
TOMTOM_OPENING_HOURS="true"

# OpenStreetMap / Overpass import
OSM_OVERPASS_URL="https://overpass-api.de/api/interpreter"
OSM_OVERPASS_TIMEOUT="180"
OSM_CACHE_FILE="cache/osm-places-serbia-v2.json"
OSM_REFRESH="false"

# Foursquare Places import
FOURSQUARE_API_KEY=""
FOURSQUARE_NEAR="Serbia"
FOURSQUARE_API_VERSION="2025-06-17"
# Leave blank for complete vendor-name coverage across pharmacies and relevant
# supplement/health shops. Setting category IDs can reduce API calls, but may
# miss shops that Foursquare classifies outside Pharmacy/Drugstore.
FOURSQUARE_CATEGORY_IDS=""
# Serbia bounds as south,west,north,east. Use "near" to fall back to one broad
# Foursquare near search per vendor, which is faster but capped at 50 results.
FOURSQUARE_COVERAGE_BOUNDS="42.2322,18.8170,46.1900,23.0063"
FOURSQUARE_MAX_SPLIT_DEPTH="8"
# Leave blank to use the app's photo-capable default field list. It requests
# photos plus rich place details such as tel, website, hours, rating, and email,
# which may require Foursquare API credits.
FOURSQUARE_FIELDS=""
FOURSQUARE_SEARCH_LIMIT="50"
FOURSQUARE_REQUEST_SLEEP="250ms"
FOURSQUARE_PRUNE_DISALLOWED="true"
FOURSQUARE_PRUNE_STALE="true"
FOURSQUARE_CONTINUE_ON_ERROR="false"
